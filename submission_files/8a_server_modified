""" 
    This is the python script that deploys the main server
    and flask application
"""

from flask import Flask, render_template, request
from EmotionDetection.emotion_detection import emotion_detector

app = Flask(__name__)

@app.route('/')
def render_index():
    """ Renders the index page."""
    return render_template("index.html")

@app.route('/emotionDetector')
def emotion_detection_page():
    """
        Calls the emotion_detector function on the input text
        and displays a formatted output.
    """
    text_to_analyze = request.args.get("textToAnalyze")
    response = emotion_detector(text_to_analyze)
    if response['dominant_emotion'] is None:
        return "Invalid text! Please try again!"
    response_str = f"\'anger\': {response['anger']}, \
    \'disgust\': {response['disgust']}, \
    \'fear\': {response['fear']}, \
    \'joy\': {response['joy']}, \
    and \'sadness\': {response['sadness']}"
    formatted_response = f"For the given statement, the system \
    response is {response_str}. The dominant emotion is \
    {response['dominant_emotion']}."
    return formatted_response

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=True)
